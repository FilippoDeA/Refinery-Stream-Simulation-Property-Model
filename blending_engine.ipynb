    "### Section 5: Commercial Execution & Supply Chain Constraints\n",
    "This final module serves as the commercial execution gate, now upgraded with physical supply chain constraints. It synthesizes the dynamic proxy market pricing, LIMS assay data, and linearized chemical constraints, while dynamically capping volumetric usage based on live tank farm inventory levels.\n",
    "\n",
    "The engine calculates a true net profit margin (incorporating variable OPEX) for a specific target batch size. Furthermore, it analyzes the optimizer's active constraints to alert the Operations desk if a specific component is bottlenecking profitability due to physical storage limits."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "8439eb5c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# =====================================================================\n",
    "# SECTION 5: EXECUTION & COMMERCIAL OUTPUT\n",
    "# =====================================================================\n",
    "\n",
    "# Ensure components list is defined in this cell's memory scope\n",
    "components = [\"Straight-run Naphtha\", \"Reformate\", \"Alkylate\", \"Butane\"]\n",
    "\n",
    "# Establish batch size and inventory levels (in barrels) for each component\n",
    "target_batch_size = 100000  # Total blend batch size in barrels\n",
    "tank_inventory = [\n",
    "    80000,   # Straight-run Naphtha inventory in barrels\n",
    "    40000,   # Reformate inventory in barrels\n",
    "    50000,   # Alkylate inventory in barrels\n",
    "    15000    # Butane inventory in barrels\n",
    "]\n",
    "\n",
    "# Run the optimizer using the live spot_prices array\n",
    "optimal_mix = run_blending_optimizer(\n",
    "    prices=spot_prices, \n",
    "    ron_specs=assay_ron, \n",
    "    rvp_idx=rvp_indices, \n",
    "    inventories=tank_inventory, \n",
    "    batch_size=target_batch_size\n",
    ")\n",
    "\n",
    "# Calculate live arbitrage margin\n",
    "variable_opex = 1.50\n",
    "\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"       COMMERCIAL TRADE SIGNAL & LOGISTICS SUMMARY\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "if optimal_mix['status'] == \"Optimal Solution Found\":\n",
    "    blend_cost = optimal_mix['cost_per_barrel']\n",
    "    net_margin = live_rbob_bbl - blend_cost - variable_opex \n",
    "    total_batch_profit = net_margin * target_batch_size\n",
    "\n",
    "    print(f\"STATUS:              [ APPROVED ]\")\n",
    "    print(f\"OPTIMIZED BLEND COST: ${blend_cost:.2f}/bbl\")\n",
    "    print(\"-\" * 60)\n",
    "    print(\"OPTIMIZED VOLUME MIX & INVENTORY CHECKS:\")\n",
    "    \n",
    "    for i in range(len(components)):\n",
    "        vol_pct = optimal_mix['volumes'][i]\n",
    "        bbls_used = vol_pct * target_batch_size\n",
    "        max_allowed_pct = optimal_mix['bounds_used'][i][1]\n",
    "        \n",
    "        # Check if the optimizer hit the physical tank limit\n",
    "        tank_warning = \"\"\n",
    "        # If the volume used is within 0.1% of the upper bound, it's maxed out\n",
    "        if abs(vol_pct - max_allowed_pct) < 0.001 and max_allowed_pct < 1.0:\n",
    "            tank_warning = \"  <-- [WARNING: TANK MAXED OUT - BOTTLENECK]\"\n",
    "            \n",
    "        print(f\"  > {components[i].ljust(22)}: {vol_pct*100:>5.1f} %  |  {int(bbls_used):>6,} bbls {tank_warning}\")\n",
    "    \n",
    "    print(\"-\" * 60)\n",
    "    print(f\"LIVE USGC 87 PRICE:   ${live_rbob_bbl:.2f}/bbl\")\n",
    "    print(f\"OPERATIONAL EXPENSE: -${variable_opex:.2f}/bbl\")\n",
    "    \n",
    "    if net_margin > 0:\n",
    "        print(f\"NET PROFIT MARGIN:    ${net_margin:.2f}/bbl  [PROFITABLE]\")\n",
    "        print(f\"TOTAL BATCH PROFIT:   ${total_batch_profit:,.2f}\")\n",
    "        print(\"\\n>>> TRADE DESK ALERT: EXECUTE BLEND & ARBITRAGE <<<\")\n",
    "    else:\n",
    "        print(f\"NET PROFIT MARGIN:    ${net_margin:.2f}/bbl  [LOSS]\")\n",
    "        print(\"\\n>>> TRADE DESK ALERT: HOLD COMPONENTS - DO NOT BLEND <<<\")\n",
    "    \n",
    "    print(\"-\" * 60)\n",
    "    print(\"SENSITIVITY ANALYSIS (SHADOW PRICING):\")\n",
    "    \n",
    "    # RVP Sensitivity\n",
    "    rvp_shadow = optimal_mix['shadow_prices']['rvp_constraint']\n",
    "    # If the marginal is non-zero, it means the constraint is actively restricting profit\n",
    "    if abs(rvp_shadow) > 0.001:\n",
    "        print(f\"  > RVP LIMIT BINDING: Relaxing RVP by 1 unit saves roughly ${abs(rvp_shadow):.2f}/bbl\")\n",
    "    else:\n",
    "        print(\"  > RVP LIMIT: Not currently bottlenecking the blend.\")\n",
    "\n",
    "    # Tank Limit Sensitivity\n",
    "    for i in range(len(components)):\n",
    "        tank_shadow = optimal_mix['shadow_prices']['tank_limits'][i]\n",
    "        if abs(tank_shadow) > 0.001:\n",
    "            print(f\"  > {components[i].upper()} TANK BINDING: Extra volume is worth ${abs(tank_shadow):.2f}/bbl premium\")\n",
    "else:\n",
    "    print(f\"STATUS:        [ REJECTED ]\")\n",
    "    print(f\"REASON:        {optimal_mix['message']}\")\n",
    "    print(\">>> TRADE DESK ALERT: BLEND INFEASIBLE DUE TO SUPPLY CHAIN OR SPECS <<<\")\n",
    "\n",
    "print(\"=\"*60)"
